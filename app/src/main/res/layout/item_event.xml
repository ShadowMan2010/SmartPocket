<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:paddingHorizontal="4dp">

    <!-- Severity dot -->
    <View
        android:id="@+id/view_severity_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_status_dot"
        android:layout_marginEnd="12dp" />

    <!-- Icon -->
    <ImageView
        android:id="@+id/iv_event_icon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="12dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_event_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/sp_text_secondary"
        android:textSize="13sp" />

    <!-- Time -->
    <TextView
        android:id="@+id/tv_event_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/sp_text_tertiary"
        android:textSize="11sp"
        android:fontFamily="monospace" />

</LinearLayout>
