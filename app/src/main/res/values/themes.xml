<resources>
    <!-- Base application theme -->
    <style name="Theme.SmartPocket" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sp_accent_primary</item>
        <item name="colorPrimaryVariant">@color/sp_accent_secondary</item>
        <item name="colorOnPrimary">@color/sp_text_primary</item>
        <item name="colorSecondary">@color/sp_accent_secondary</item>
        <item name="colorOnSecondary">@color/sp_background</item>
        <item name="android:colorBackground">@color/sp_background</item>
        <item name="android:windowBackground">@color/sp_background</item>
        <item name="colorSurface">@color/sp_surface</item>
        <item name="colorOnSurface">@color/sp_text_primary</item>
        <item name="android:statusBarColor">@color/sp_background</item>
        <item name="android:navigationBarColor">@color/sp_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="textAppearanceHeadline1">@style/TextAppearance.SmartPocket.H1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.SmartPocket.H2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.SmartPocket.Body</item>
        <item name="textAppearanceCaption">@style/TextAppearance.SmartPocket.Caption</item>
        <item name="bottomNavigationStyle">@style/Style.SmartPocket.BottomNav</item>
    </style>

    <!-- Lockdown theme: full dark, no decorations -->
    <style name="Theme.SmartPocket.Lockdown" parent="Theme.SmartPocket">
        <item name="android:colorBackground">@color/sp_lockdown_bg</item>
        <item name="android:windowBackground">@color/sp_lockdown_bg</item>
        <item name="android:statusBarColor">@color/sp_lockdown_bg</item>
        <item name="android:navigationBarColor">@color/sp_lockdown_bg</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.SmartPocket.H1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textColor">@color/sp_text_primary</item>
    </style>

    <style name="TextAppearance.SmartPocket.H2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textColor">@color/sp_text_primary</item>
    </style>

    <style name="TextAppearance.SmartPocket.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
        <item name="android:textColor">@color/sp_text_secondary</item>
    </style>

    <style name="TextAppearance.SmartPocket.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/sp_text_tertiary</item>
    </style>

    <style name="TextAppearance.SmartPocket.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/sp_text_tertiary</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Style.SmartPocket.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/sp_surface</item>
        <item name="itemIconTint">@color/selector_nav_icon</item>
        <item name="itemTextColor">@color/selector_nav_icon</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Card style -->
    <style name="Style.SmartPocket.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/sp_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/sp_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Status Card - Safe -->
    <style name="Style.SmartPocket.Card.Safe" parent="Style.SmartPocket.Card">
        <item name="strokeColor">@color/sp_safe_dim</item>
    </style>

    <!-- Status Card - Warning -->
    <style name="Style.SmartPocket.Card.Warning" parent="Style.SmartPocket.Card">
        <item name="strokeColor">@color/sp_warning_dim</item>
    </style>

    <!-- Status Card - Danger -->
    <style name="Style.SmartPocket.Card.Danger" parent="Style.SmartPocket.Card">
        <item name="strokeColor">@color/sp_danger_dim</item>
    </style>

    <!-- Primary Button -->
    <style name="Style.SmartPocket.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/sp_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Secondary / Outlined Button -->
    <style name="Style.SmartPocket.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/sp_accent_light</item>
        <item name="strokeColor">@color/sp_border</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Danger Button -->
    <style name="Style.SmartPocket.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/sp_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Switch -->
    <style name="Style.SmartPocket.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/selector_switch_thumb</item>
        <item name="trackTint">@color/selector_switch_track</item>
    </style>
</resources>
