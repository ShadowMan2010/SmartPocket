<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.smartpocket.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_face"
            app:destination="@id/nav_face"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_home_to_bluetooth"
            app:destination="@id/nav_bluetooth"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/nav_face"
        android:name="com.smartpocket.ui.faceauth.FaceAuthFragment"
        android:label="Face ID" />

    <fragment
        android:id="@+id/nav_bluetooth"
        android:name="com.smartpocket.ui.bluetooth.BluetoothFragment"
        android:label="Bluetooth" />

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.smartpocket.ui.settings.SettingsFragment"
        android:label="Settings" />

</navigation>
