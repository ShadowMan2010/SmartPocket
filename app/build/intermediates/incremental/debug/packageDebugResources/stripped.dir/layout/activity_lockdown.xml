<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sp_lockdown_bg">

    <!-- Subtle radial gradient overlay (simulated with a view) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_lockdown_overlay" />

    <!-- Warning stripes top -->
    <View
        android:id="@+id/view_stripe_top"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/sp_lockdown_accent"
        android:alpha="0.8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Warning stripes bottom -->
    <View
        android:id="@+id/view_stripe_bottom"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/sp_lockdown_accent"
        android:alpha="0.8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Status label -->
    <TextView
        android:id="@+id/tv_lockdown_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="SECURITY ALERT"
        android:textColor="@color/sp_lockdown_accent"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.16"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lock icon (large) -->
    <FrameLayout
        android:id="@+id/layout_lock_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_lockdown_circle"
        app:layout_constraintTop_toBottomOf="@id/tv_lockdown_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lock"
            android:tint="@color/sp_lockdown_accent" />

    </FrameLayout>

    <!-- Lockdown title -->
    <TextView
        android:id="@+id/tv_lockdown_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/lockdown_title"
        android:textColor="@color/sp_text_primary"
        android:textSize="28sp"
        android:fontFamily="sans-serif-thin"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/layout_lock_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_lockdown_message"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/lockdown_message"
        android:textColor="@color/sp_text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        app:layout_constraintTop_toBottomOf="@id/tv_lockdown_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tv_lockdown_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/sp_text_tertiary"
        android:textSize="12sp"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toBottomOf="@id/tv_lockdown_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Verify button -->
    <Button
        android:id="@+id/btn_verify_identity"
        style="@style/Style.SmartPocket.Button.Primary"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:text="@string/lockdown_verify"
        app:layout_constraintBottom_toTopOf="@id/btn_emergency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Emergency contact -->
    <Button
        android:id="@+id/btn_emergency"
        style="@style/Style.SmartPocket.Button.Secondary"
        android:layout_width="280dp"
        android:layout_height="52dp"
        android:layout_marginBottom="48dp"
        android:text="@string/lockdown_emergency"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Attempt counter -->
    <TextView
        android:id="@+id/tv_attempts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:textColor="@color/sp_text_tertiary"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/btn_verify_identity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
